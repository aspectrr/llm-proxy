# Bifrost admin password (used for auth and metrics scraping)
ADMIN_PASSWORD=changeme

# Provider API keys
OPENROUTER_API_KEY=
GLM_API_KEY=
OLLAMA_URL=http://host.docker.internal:11434

# Supabase (for metrics scraper)
# Local dev: use values from `supabase status`
# Production: use your Supabase project URL and service_role key
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_KEY=
SCRAPE_INTERVAL_SECONDS=60
